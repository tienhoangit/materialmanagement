<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog
        id="poDetailDialog"
        title="{i18n>purchaseOrderDetails}"
        contentWidth="52rem">
        <content>
            <VBox class="sapUiSmallMargin">
                <ObjectHeader
                    id="poDetailObjectHeader"
                    title="{poItems>/header/Ebeln}"
                    intro="{i18n>poHeaderInfo}">
                    <attributes>
                        <ObjectAttribute title="{i18n>supplier}" text="{poItems>/header/Lifnr}" />
                        <ObjectAttribute title="{i18n>companyCode}" text="{poItems>/header/Bukrs}" />
                        <ObjectAttribute title="{i18n>documentType}" text="{poItems>/header/Bsart}" />
                        <ObjectAttribute title="{i18n>documentDate}" text="{poItems>/header/Bedat}" />
                    </attributes>
                </ObjectHeader>
                <Title text="{i18n>poItems}" level="H4" class="sapUiSmallMarginTopBottom" />
                <Table
                    width="100%"
                    noDataText="{i18n>noPurchaseOrderItems}"
                    items="{poItems>/items}">
                    <columns>
                        <Column width="5rem"><Text text="{i18n>poItem}" /></Column>
                        <Column><Text text="{i18n>material}" /></Column>
                        <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>itemDescription}" /></Column>
                        <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>plant} / {i18n>storageLocation}" /></Column>
                        <Column hAlign="End"><Text text="{i18n>orderQuantity}" /></Column>
                        <Column hAlign="End"><Text text="{i18n>netPrice}" /></Column>
                        <Column hAlign="Center" width="4rem"><Text text="" /></Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{poItems>Ebelp}" />
                                <Text text="{poItems>Matnr}" />
                                <Text text="{poItems>Txz01}" />
                                <Text text="{poItems>Werks} / {poItems>Lgort}" />
                                <ObjectNumber number="{poItems>Menge}" unit="{poItems>Meins}" />
                                <ObjectNumber number="{poItems>Netpr}" />
                                <Button icon="sap-icon://shipping-status" tooltip="{i18n>postGoodsReceipt}" press="._openGoodsReceiptForItem" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
        <buttons>
            <Button text="{i18n>postGoodsReceipt}" type="Emphasized" press=".onPostGrFromDetail" />
            <Button text="{i18n>cancel}" press=".onClosePoDetailDialog" />
        </buttons>
    </Dialog>
</core:FragmentDefinition>
