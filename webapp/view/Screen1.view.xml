<mvc:View controllerName="materialmanagement.controller.Screen1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">
    <Page id="page" title="{i18n>title}" showHeader="true">
        <headerContent>
            <Button icon="sap-icon://refresh" type="Transparent" tooltip="{i18n>refresh}" press="onRefresh" />
        </headerContent>
        <content>
            <IconTabBar id="mainTabs" class="sapUiResponsiveContentPadding" expandable="false">
                <items>
                    <!-- TAB OVERVIEW: Hiển thị các thẻ tóm tắt (số lượng) và danh sách Purchase Order mới nhất -->
                    <IconTabFilter key="overview" text="{i18n>overview}" icon="sap-icon://home">
                        <VBox class="sapUiSmallMargin">
                            <ObjectHeader title="{i18n>welcomeTitle}" intro="{i18n>welcomeIntro}" icon="sap-icon://cart-approval" />
                            <HBox wrap="Wrap" class="summaryCards">
                                <VBox class="summaryCard">
                                    <ObjectNumber number="{viewModel>/materialCount}" unit="{i18n>materials}" state="Information" />
                                    <Text text="{i18n>materialCatalog}" />
                                </VBox>
                                <VBox class="summaryCard">
                                    <ObjectNumber number="{viewModel>/stockCount}" unit="{i18n>stockLines}" state="Success" />
                                    <Text text="{i18n>stockOverview}" />
                                </VBox>
                                <VBox class="summaryCard">
                                    <ObjectNumber number="{viewModel>/poCount}" unit="{i18n>purchaseOrders}" state="Warning" />
                                    <Text text="{i18n>orderOverview}" />
                                </VBox>
                            </HBox>
                            <Table id="orderTable" items="{/PurchaseOrderSet}" growing="true" growingThreshold="10" noDataText="{i18n>noOrders}" updateFinished="onOrderTableUpdateFinished">
                                <headerToolbar>
                                    <OverflowToolbar>
                                        <Title text="{i18n>recentOrders}" level="H3" />
                                        <ToolbarSpacer />
                                        <Select id="selectPoSearchField" change="onPOSearch" selectedKey="Ebeln" width="10rem">
                                            <items>
                                                <core:Item key="Ebeln" text="{i18n>poNumber}" />
                                                <core:Item key="Lifnr" text="{i18n>supplier}" />
                                                <core:Item key="Bukrs" text="{i18n>companyCode}" />
                                            </items>
                                        </Select>
                                        <SearchField id="searchPoInput" width="14rem" placeholder="{i18n>searchPoPlaceholder}" search="onPOSearch" liveChange="onPOSearch" />
                                    </OverflowToolbar>
                                </headerToolbar>
                                <columns>
                                    <Column><Text text="{i18n>poNumber}" /></Column>
                                    <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>supplier}" /></Column>
                                    <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>companyCode}" /></Column>
                                    <Column hAlign="End"><Text text="{i18n>documentDate}" /></Column>
                                </columns>
                                <items>
                                    <ColumnListItem type="Active" press="onPurchaseOrderPress">
                                        <cells>
                                            <ObjectIdentifier title="{Ebeln}" titleActive="true" titlePress="onPurchaseOrderPress" />
                                            <Text text="{Lifnr}" />
                                            <Text text="{Bukrs}" />
                                            <Text text="{Bedat}" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </VBox>
                    </IconTabFilter>
                    <!-- TAB MATERIALS: Hiển thị danh mục Vật tư (Material) và thanh tìm kiếm theo Matnr -->
                    <IconTabFilter key="materials" text="{i18n>materialsStock}" icon="sap-icon://product">
                        <VBox class="sapUiSmallMargin">
                            <Title text="{i18n>materialCatalog}" level="H3" />
                            <Table id="materialTable" items="{/MaterialSet}" growing="true" growingThreshold="20" noDataText="{i18n>noMaterials}" updateFinished="onMaterialTableUpdateFinished">
                                <headerToolbar><Toolbar><ToolbarSpacer /><SearchField width="12rem" placeholder="{i18n>searchMaterial}" search="onMaterialSearch" liveChange="onMaterialSearch" /></Toolbar></headerToolbar>
                                <columns>
                                    <Column><Text text="{i18n>material}" /></Column>
                                    <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>materialType}" /></Column>
                                    <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>materialGroup}" /></Column>
                                    <Column hAlign="End"><Text text="{i18n>baseUnit}" /></Column>
                                </columns>
                                <items>
                                    <ColumnListItem><cells><Text text="{Matnr}" /><Text text="{Mtart}" /><Text text="{Matkl}" /><Text text="{Meins}" /></cells></ColumnListItem>
                                </items>
                            </Table>
                            <Title text="{i18n>stockOverview}" level="H3" class="sapUiMediumMarginTop" />
                            <Table id="stockTable" items="{/StockSet}" growing="true" growingThreshold="20" noDataText="{i18n>noStock}" updateFinished="onStockTableUpdateFinished">
                            <headerToolbar><Toolbar><Title text="{i18n>stockOverview}" /><ToolbarSpacer /><SearchField width="12rem" search="onStockSearch" liveChange="onStockSearch" /></Toolbar></headerToolbar>
                            <columns>
                                <Column><Text text="{i18n>material}" /></Column>
                                <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>plant}" /></Column>
                                <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>storageLocation}" /></Column>
                                <Column hAlign="End"><Text text="{i18n>availableStock}" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells><Text text="{Matnr}" /><Text text="{Werks}" /><Text text="{Lgort}" /><ObjectNumber number="{Labst}" /></cells>
                                </ColumnListItem>
                            </items>
                            </Table>
                        </VBox>
                    </IconTabFilter>
                    <!-- TAB GOODS RECEIPTS: Hiển thị danh sách Phiếu nhập kho (Goods Receipt) -->
                    <IconTabFilter key="goodsReceipt" text="{i18n>goodsReceipts}" icon="sap-icon://shipping-status">
                        <VBox class="sapUiSmallMargin">
                            <Table id="goodsReceiptTable" items="{/GoodsReceiptSet}" growing="true" growingThreshold="20" noDataText="{i18n>noGoodsReceipts}">
                                <headerToolbar>
                                    <OverflowToolbar>
                                        <Title text="{i18n>goodsReceipts}" />
                                        <ToolbarSpacer />
                                        <SearchField width="14rem" placeholder="{i18n>searchGrPlaceholder}" search="onGRSearch" liveChange="onGRSearch" />
                                        <Button text="{i18n>postGoodsReceipt}" icon="sap-icon://add" type="Emphasized" press="onOpenGoodsReceipt" />
                                    </OverflowToolbar>
                                </headerToolbar>
                                <columns>
                                    <Column><Text text="{i18n>poNumber}" /></Column>
                                    <Column><Text text="{i18n>poItem}" /></Column>
                                    <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>goodsReceiptDocument}" /></Column>
                                    <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>postingDate}" /></Column>
                                    <Column hAlign="End"><Text text="{i18n>quantity}" /></Column>
                                </columns>
                                <items>
                                    <ColumnListItem><cells><Text text="{Ebeln}" /><Text text="{Ebelp}" /><Text text="{Belnr}" /><Text text="{Budat}" /><ObjectNumber number="{Menge}" /></cells></ColumnListItem>
                                </items>
                            </Table>
                        </VBox>
                    </IconTabFilter>
                    <IconTabFilter key="create" text="{i18n>createOrder}" icon="sap-icon://add-document">
                        <VBox class="sapUiMediumMargin">
                            <Title text="{i18n>createOrderTitle}" level="H2" />
                            <Text text="{i18n>createOrderHint}" class="sapUiTinyMarginBottom" />
                            <Button text="{i18n>createOrder}" icon="sap-icon://add" type="Emphasized" press="onOpenCreateOrder" />
                        </VBox>
                    </IconTabFilter>
                </items>
            </IconTabBar>
        </content>
    </Page>
</mvc:View>
